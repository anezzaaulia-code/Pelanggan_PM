<resources>

    <style name="Theme.Pelanggan_PM" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/cream_primary</item>
        <item name="colorOnPrimary">@color/text_dark</item>

        <item name="colorPrimaryContainer">@color/cream_soft</item>
        <item name="colorOnPrimaryContainer">@color/brown_text</item>

        <item name="colorSecondary">@color/cream_primary_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorSecondaryContainer">@color/cream_soft</item>
        <item name="colorOnSecondaryContainer">@color/brown_text</item>

        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_dark</item>

        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/cream_light</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowBackground">@color/cream_light</item>
        <item name="android:forceDarkAllowed">false</item>

        <item name="popupMenuStyle">@style/Widget.SiTahu.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.SiTahu.PopupMenu</item>
    </style>

    <style name="ThemeOverlay.SiTahu.PopupMenu" parent="ThemeOverlay.Material3.Light">
        <item name="colorSurface">@color/white</item>
        <item name="android:colorBackground">@color/white</item>
        <item name="android:textColorPrimary">@color/text_dark</item>
        <item name="android:textColorSecondary">@color/text_gray</item>
    </style>

    <style name="Widget.SiTahu.PopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_menu_sitahu</item>
    </style>

</resources>