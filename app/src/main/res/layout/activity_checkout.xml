<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F3"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- JUDUL -->
        <TextView
            android:id="@+id/txtJudulCheckout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Checkout"
            android:textColor="#285234"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtInfoKeranjang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Keranjang kosong"
            android:textColor="#7B8A7B"
            android:textSize="14sp" />

        <!-- RINGKASAN PRODUK -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="#E2E8DD"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ringkasan Produk"
                    android:textColor="#285234"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtRingkasan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:lineSpacingExtra="4dp"
                    android:text="Belum ada produk yang dipilih."
                    android:textColor="#4F5B4A"
                    android:textSize="14sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- METODE PENGAMBILAN -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="#E2E8DD"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Metode Pengambilan"
                    android:textColor="#285234"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgMetode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbAmbil"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#3E7B3B"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="Ambil di Toko"
                        android:textColor="#333333"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/rbKurir"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="#3E7B3B"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="Kurir Toko"
                        android:textColor="#333333"
                        android:textSize="15sp" />

                </RadioGroup>

                <TextView
                    android:id="@+id/txtAlamatInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Alamat toko akan digunakan untuk metode Ambil di Toko."
                    android:textColor="#6E776A"
                    android:textSize="14sp" />

                <Spinner
                    android:id="@+id/spAlamat"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="#F5F7F3"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTambahAlamat"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:text="Tambah Alamat"
                    android:textAllCaps="false"
                    android:textColor="#285234"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:backgroundTint="#DDEFE5"
                    app:cornerRadius="25dp"
                    app:elevation="0dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- METODE PEMBAYARAN -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="#E2E8DD"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Metode Pembayaran"
                    android:textColor="#285234"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spMetodeBayar"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="#F5F7F3"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />

                <CheckBox
                    android:id="@+id/cbSetuju"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:buttonTint="#3E7B3B"
                    android:text="Saya setuju pesanan diproses sesuai data checkout"
                    android:textColor="#4F5B4A"
                    android:textSize="14sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- TOTAL PEMBAYARAN -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#285234"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Total Pembayaran"
                    android:textColor="#DDEFE5"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/txtTotal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Rp0"
                    android:textColor="#FFFFFF"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBuatPesanan"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="18dp"
                    android:text="Buat Pesanan"
                    android:textAllCaps="false"
                    android:textColor="#2D2A18"
                    android:textStyle="bold"
                    app:backgroundTint="#F4C542"
                    app:cornerRadius="26dp"
                    app:elevation="0dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>