<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootCheckout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream_light"
    android:fitsSystemWindows="true">

    <View
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-65dp"
        android:layout_marginEnd="-55dp"
        android:alpha="0.45"
        android:background="@drawable/bg_circle_gold_soft" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="24dp"
                android:paddingEnd="20dp"
                android:paddingBottom="22dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Selesaikan pesanan"
                    android:textColor="@color/text_gray"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Checkout"
                    android:textColor="@color/text_dark"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtInfoKeranjang"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Produk siap di-checkout"
                    android:textColor="@color/text_gray"
                    android:textSize="14sp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_soft"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Ringkasan Pesanan"
                            android:textColor="@color/text_dark"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtRingkasan"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_note_box"
                            android:lineSpacingExtra="4dp"
                            android:padding="14dp"
                            android:text="Belum ada produk yang dipilih."
                            android:textColor="@color/text_gray"
                            android:textSize="14sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_soft"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Metode Pengambilan"
                            android:textColor="@color/text_dark"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <RadioGroup
                            android:id="@+id/rgMetode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="vertical">

                            <RadioButton
                                android:id="@+id/rbAmbil"
                                android:layout_width="match_parent"
                                android:layout_height="58dp"
                                android:background="@drawable/bg_payment_option"
                                android:buttonTint="@color/cream_primary_dark"
                                android:checked="true"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:text="Ambil di Toko"
                                android:textColor="@color/text_dark"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <RadioButton
                                android:id="@+id/rbKurir"
                                android:layout_width="match_parent"
                                android:layout_height="58dp"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_payment_option"
                                android:buttonTint="@color/cream_primary_dark"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:text="Kurir Toko"
                                android:textColor="@color/text_dark"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                        </RadioGroup>

                        <TextView
                            android:id="@+id/txtAlamatInfo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_note_box"
                            android:lineSpacingExtra="3dp"
                            android:padding="14dp"
                            android:text="Alamat toko akan digunakan untuk metode Ambil di Toko."
                            android:textColor="@color/text_gray"
                            android:textSize="14sp" />

                        <Spinner
                            android:id="@+id/spAlamat"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_input_cream"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:visibility="gone" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTambahAlamat"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="12dp"
                            android:text="Tambah / Kelola Alamat"
                            android:textAllCaps="false"
                            android:textColor="@color/brown_text"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:visibility="gone"
                            app:backgroundTint="@color/cream_soft"
                            app:cornerRadius="18dp"
                            app:elevation="0dp"
                            app:strokeColor="@color/cream_primary"
                            app:strokeWidth="1dp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_soft"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Jadwal Pesanan"
                            android:textColor="@color/text_dark"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:lineSpacingExtra="2dp"
                            android:text="Pilih tanggal dan jam ambil/kirim pesanan."
                            android:textColor="@color/text_gray"
                            android:textSize="13sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Tanggal"
                                android:textColor="@color/text_gray"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="54dp"
                                android:layout_marginTop="6dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/txtTanggalPesanan"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_input_cream"
                                    android:gravity="center_vertical"
                                    android:paddingStart="14dp"
                                    android:paddingEnd="14dp"
                                    android:singleLine="true"
                                    android:text="Tanggal belum dipilih"
                                    android:textColor="@color/text_gray"
                                    android:textSize="14sp" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnPilihTanggal"
                                    android:layout_width="104dp"
                                    android:layout_height="match_parent"
                                    android:layout_marginStart="10dp"
                                    android:insetTop="0dp"
                                    android:insetBottom="0dp"
                                    android:minWidth="0dp"
                                    android:minHeight="0dp"
                                    android:singleLine="true"
                                    android:text="Pilih"
                                    android:textAllCaps="false"
                                    android:textColor="@color/text_dark"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    app:backgroundTint="@color/cream_primary"
                                    app:cornerRadius="18dp"
                                    app:elevation="0dp" />

                            </LinearLayout>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Jam"
                                android:textColor="@color/text_gray"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="54dp"
                                android:layout_marginTop="6dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/txtJamPesanan"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_input_cream"
                                    android:gravity="center_vertical"
                                    android:paddingStart="14dp"
                                    android:paddingEnd="14dp"
                                    android:singleLine="true"
                                    android:text="Jam belum dipilih"
                                    android:textColor="@color/text_gray"
                                    android:textSize="14sp" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnPilihJam"
                                    android:layout_width="104dp"
                                    android:layout_height="match_parent"
                                    android:layout_marginStart="10dp"
                                    android:insetTop="0dp"
                                    android:insetBottom="0dp"
                                    android:minWidth="0dp"
                                    android:minHeight="0dp"
                                    android:singleLine="true"
                                    android:text="Pilih"
                                    android:textAllCaps="false"
                                    android:textColor="@color/text_dark"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    app:backgroundTint="@color/cream_primary"
                                    app:cornerRadius="18dp"
                                    app:elevation="0dp" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_soft"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Metode Pembayaran"
                            android:textColor="@color/text_dark"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <Spinner
                            android:id="@+id/spMetodeBayar"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_input_cream"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />

                        <TextView
                            android:id="@+id/txtInfoPembayaran"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:lineSpacingExtra="2dp"
                            android:text="Pembayaran tersedia: COD / tunai dan transfer bank. QR Code digunakan untuk validasi pengambilan pesanan, bukan QRIS."
                            android:textColor="@color/text_gray"
                            android:textSize="13sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/cream_soft"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/cream_primary"
                    app:strokeWidth="1dp">

                    <CheckBox
                        android:id="@+id/cbSetuju"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/cream_primary_dark"
                        android:padding="16dp"
                        android:text="Saya sudah mengecek pesanan dan setuju membuat pesanan."
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </ScrollView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="0dp"
            app:cardElevation="10dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="14dp"
                android:paddingEnd="20dp"
                android:paddingBottom="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total Pembayaran"
                        android:textColor="@color/text_gray"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/txtTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp0"
                        android:textColor="@color/brown_text"
                        android:textSize="23sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBuatPesanan"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="14dp"
                    android:text="Buat Pesanan"
                    android:textAllCaps="false"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/cream_primary"
                    app:cornerRadius="20dp"
                    app:elevation="0dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</FrameLayout>