<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:text="✅ Checkout"
            android:textColor="@color/brand_dark"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtJudulCheckout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Lengkapi data pesanan."
            android:textColor="@color/brown"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtInfoKeranjang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Keranjang kosong"
            android:textColor="@color/muted"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ringkasan Produk"
                android:textColor="@color/brown"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtRingkasan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="4dp"
                android:text="Belum ada produk yang dipilih."
                android:textColor="@color/muted"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Metode Pengambilan"
                android:textColor="@color/brown"
                android:textSize="18sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgMetode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbAmbil"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_radio_option"
                    android:buttonTint="@color/brand_dark"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Ambil di toko"
                    android:textColor="@color/brown"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/rbKurir"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_radio_option"
                    android:buttonTint="@color/brand_dark"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Kurir toko"
                    android:textColor="@color/brown"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </RadioGroup>

            <TextView
                android:id="@+id/txtAlamatInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Alamat toko akan digunakan untuk metode Ambil di Toko. Tidak ada biaya kurir."
                android:textColor="@color/muted"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/spAlamat"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTambahAlamat"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="12dp"
                android:text="Tambah Alamat"
                android:textAllCaps="false"
                android:textColor="@color/brand_dark"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="@color/brand_soft"
                app:cornerRadius="15dp"
                app:elevation="0dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Metode Pembayaran"
                android:textColor="@color/brown"
                android:textSize="18sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgPembayaran"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbTunai"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_radio_option"
                    android:buttonTint="@color/brand_dark"
                    android:checked="true"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Tunai"
                    android:textColor="@color/brown"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/rbQris"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_radio_option"
                    android:buttonTint="@color/brand_dark"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="QRIS"
                    android:textColor="@color/brown"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </RadioGroup>

            <CheckBox
                android:id="@+id/cbSetuju"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:buttonTint="@color/brand_dark"
                android:text="Saya setuju pesanan diproses sesuai data checkout"
                android:textColor="@color/muted"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_summary"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total Pembayaran"
                android:textColor="@color/brand_dark"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Rp0"
                android:textColor="@color/brown"
                android:textSize="25sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBuatPesanan"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:text="Buat Pesanan"
                android:textAllCaps="false"
                android:textColor="@color/brown"
                android:textStyle="bold"
                app:backgroundTint="@color/brand"
                app:cornerRadius="16dp"
                app:elevation="0dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>