<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream_light">

    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-70dp"
        android:layout_marginEnd="-55dp"
        android:alpha="0.55"
        android:background="@drawable/bg_circle_gold_soft" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="22dp"
            android:paddingEnd="20dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bagikan pengalamanmu ✨"
                android:textColor="@color/text_gray"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtTitleUlasan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ulasan Produk"
                android:textColor="@color/text_dark"
                android:textSize="31sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSubtitleUlasan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Beri rating, komentar, dan foto untuk produk tahu yang kamu pesan."
                android:textColor="@color/text_gray"
                android:textSize="14sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="@color/cream_primary"
                app:cardCornerRadius="26dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_badge_cream"
                        android:gravity="center"
                        android:paddingStart="13dp"
                        android:paddingEnd="13dp"
                        android:text="ULASAN PEMBELI"
                        android:textColor="@color/brown_text"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Ceritakan kualitas produk, rasa, pelayanan, atau pengalaman pesananmu."
                        android:textColor="@color/text_dark"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtInfoProdukUlasan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Ulasan akan membantu pembeli lain memilih produk MAR Tahu."
                        android:textColor="@color/brown_text"
                        android:textSize="13sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="26dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:background="@drawable/bg_circle_gold_soft"
                            android:gravity="center"
                            android:text="⭐"
                            android:textSize="21sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Rating Produk"
                                android:textColor="@color/text_dark"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Pilih jumlah bintang sesuai pengalamanmu."
                                android:textColor="@color/text_gray"
                                android:textSize="12sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <RatingBar
                        android:id="@+id/ratingBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:numStars="5"
                        android:rating="5"
                        android:stepSize="1" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Komentar Ulasan"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edtKomentar"
                        android:layout_width="match_parent"
                        android:layout_height="130dp"
                        android:layout_marginTop="9dp"
                        android:background="@drawable/bg_input_cream"
                        android:gravity="top"
                        android:hint="Contoh: Tahunya fresh, pelayanan cepat, cocok untuk lauk keluarga..."
                        android:inputType="textMultiLine"
                        android:maxLines="6"
                        android:minLines="4"
                        android:padding="14dp"
                        android:textColor="@color/text_dark"
                        android:textColorHint="@color/text_gray"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Foto Ulasan"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="190dp"
                        android:layout_marginTop="9dp"
                        android:background="@drawable/bg_product_image">

                        <ImageView
                            android:id="@+id/imgPreview"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="Preview foto ulasan"
                            android:scaleType="centerCrop" />

                        <LinearLayout
                            android:id="@+id/emptyPreview"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="72dp"
                                android:layout_height="72dp"
                                android:background="@drawable/bg_circle_gold_soft"
                                android:gravity="center"
                                android:text="📷"
                                android:textSize="30sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="Belum ada foto"
                                android:textColor="@color/brown_text"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="Ambil foto produk jika ingin menambahkan bukti ulasan."
                                android:textColor="@color/text_gray"
                                android:textSize="11sp" />

                        </LinearLayout>

                    </FrameLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnKamera"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:text="Ambil Foto dengan Kamera"
                        android:textAllCaps="false"
                        android:textColor="@color/brown_text"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/cream_soft"
                        app:cornerRadius="24dp"
                        app:elevation="0dp"
                        app:iconTint="@color/brown_text"
                        app:strokeColor="@color/cream_primary"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnKirimUlasan"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="12dp"
                        android:text="Kirim Ulasan"
                        android:textAllCaps="false"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/cream_primary"
                        app:cornerRadius="27dp"
                        app:elevation="0dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</FrameLayout>