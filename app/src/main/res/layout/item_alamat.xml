<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/card"
    app:cardCornerRadius="22dp"
    app:cardElevation="3dp"
    app:strokeColor="@color/line"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtNamaPenerima"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Martha"
                android:textColor="@color/brown"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtUtama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip"
                android:paddingStart="10dp"
                android:paddingTop="5dp"
                android:paddingEnd="10dp"
                android:paddingBottom="5dp"
                android:text="Utama"
                android:textColor="@color/brand_dark"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtTelepon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="0812-3456-7890"
            android:textColor="@color/muted"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtAlamatLengkap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Jl. Contoh alamat lengkap"
            android:textColor="@color/brown"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtKoordinat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Lat: -7.000, Lng: 112.000"
            android:textColor="@color/muted"
            android:textSize="12sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>