<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/frameContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_app" />

    <LinearLayout
        android:id="@+id/customBottomNav"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="10dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingTop="8dp"
        android:paddingEnd="10dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:id="@+id/navBeranda"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_marginHorizontal="3dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="7dp"
            android:paddingBottom="7dp">

            <TextView
                android:id="@+id/iconBeranda"
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="👁"
                android:textColor="@color/brand_dark"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/textBeranda"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:gravity="center"
                android:text="Beranda"
                android:textColor="@color/brand_dark"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProduk"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_marginHorizontal="3dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="7dp"
            android:paddingBottom="7dp">

            <TextView
                android:id="@+id/iconProduk"
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="🔍"
                android:textColor="@color/brand_dark"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/textProduk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:gravity="center"
                android:text="Produk"
                android:textColor="@color/brand_dark"
                android:textSize="11sp"
                android:textStyle="normal" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navKeranjang"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_marginHorizontal="3dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="7dp"
            android:paddingBottom="7dp">

            <TextView
                android:id="@+id/iconKeranjang"
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="⊕"
                android:textColor="@color/brand_dark"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/textKeranjang"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:gravity="center"
                android:text="Keranjang"
                android:textColor="@color/brand_dark"
                android:textSize="11sp"
                android:textStyle="normal" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPesanan"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_marginHorizontal="3dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="7dp"
            android:paddingBottom="7dp">

            <TextView
                android:id="@+id/iconPesanan"
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="▣"
                android:textColor="@color/brand_dark"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/textPesanan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:gravity="center"
                android:text="Pesanan"
                android:textColor="@color/brand_dark"
                android:textSize="11sp"
                android:textStyle="normal" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfil"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_marginHorizontal="3dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="7dp"
            android:paddingBottom="7dp">

            <TextView
                android:id="@+id/iconProfil"
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="♟"
                android:textColor="@color/brand_dark"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/textProfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:gravity="center"
                android:text="Profil"
                android:textColor="@color/brand_dark"
                android:textSize="11sp"
                android:textStyle="normal" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>