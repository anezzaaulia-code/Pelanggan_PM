<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="96dp"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <ImageView
            android:id="@+id/imgProdukCart"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:background="#FFF4C8"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtNamaCart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tahu Kuning"
                android:textColor="#073D2B"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtHargaCart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rp12.000 / pack"
                android:textColor="#7B8A7B"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnMinus"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:backgroundTint="#DDEFE5"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    android:text="-"
                    android:textColor="#073D2B" />

                <TextView
                    android:id="@+id/txtJumlah"
                    android:layout_width="34dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="#073D2B"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnPlus"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:backgroundTint="#DDEFE5"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    android:text="+"
                    android:textColor="#073D2B" />

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/txtSubtotalCart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp24k"
            android:textColor="#073D2B"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>